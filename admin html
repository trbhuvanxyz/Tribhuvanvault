<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>
</head>

<body style="background:black;color:white;font-family:Arial;text-align:center">

  <h1>Add Song 🤘</h1>

  <input id="name" placeholder="Song Name"><br><br>
  <input id="artist" placeholder="Artist"><br><br>
  <input id="file" placeholder="MP3 URL"><br><br>

  <button onclick="addSong()">Add Song</button>

  <script>
    // FULLY UPGRADED FUNCTION
    async function addSong() {

      let song = {
        name: document.getElementById("name").value,
        artist: document.getElementById("artist").value,
        file: document.getElementById("file").value
      };

      // POST song to backend
      await fetch("https://tribhuvanvault.onrender.com/add-song", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(song)
      });

      alert("Song Added 🤘");

      // Clear inputs after adding
      document.getElementById("name").value = "";
      document.getElementById("artist").value = "";
      document.getElementById("file").value = "";
    }
  </script>

</body>
</html>
