CTYPE html>
<html>
<head>
  <title>RockVault Admin Panel</title>
  <style>
    body {
      background: rgb(249, 2, 2);
      color: rgb(76, 4, 124);
      font-family: Arial, sans-serif;
      text-align: center;
    }
    input {
      padding: 8px;
      margin: 5px;
      width: 250px;
    }
    button {
      padding: 10px 20px;
      margin: 10px;
      background: #1e1e1e;
      color: white;
      border: 1px solid #555;
      cursor: pointer;
    }
    button:hover {
      background: #555;
    }
    img {
      width: 150px;
      border-radius: 50%;
      margin: 20px;
    }
    .container {
      margin-top: 30px;
    }
  </style>
</head>

<body>

  <h1>RockVault Admin Panel 🤘</h1>

  <!-- About Me Section -->
  <img src="photo.jpg" alt="Tribhuvans">
  <h2>Tribhuvans Singh Shekhawat</h2>
  <p style="color:rgba(74, 4, 87, 0.232);">About Me: Rock and Metal Music Collector, gradauted from Manipal University Jaipur
    with a degree in Bachelor of Computer Applications and will graduate again with Masters of Computer Applications,
    I love Metal, Rock, UFC, Wrestling, Dogs, so much more, not a traveller or an out going person,
    close the Kick Streamers and Open up a Book, get some wisdom while your at it, these people, 
    will never help, books will. Instagram is tribhuvan.rockhard and I write books. Metalhead for life y'all.
    I support No Iran, No Israel, No Ukraine, I only support my Novels and some beautiful women.<Testimonial-Tribhuvan-Singh-Shekh></Testimonial-Tribhuvan-Singh-Shekh>
  </p>

  <div class="container">
    <h2>Add Rock & Metal Songs</h2>

    <input id="name" placeholder="Song Name"><br>
    <input id="artist" placeholder="Artist"><br>
    <input id="file" placeholder="MP3 URL"><br>
    <button onclick="addSong()">Add Song</button>
    <button onclick="addAllSongs()">Add Bulk Songs</button>
  </div>

  <script>
    // Manual add single song
    async function addSong() {
      let song = {
        name: document.getElementById("name").value,
        artist: document.getElementById("artist").value,
        file: document.getElementById("file").value
      };

      await fetch("https://tribhuvanvault.onrender.com/add-song", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(song)
      });

      alert("Song Added 🤘");

      // Clear inputs
      document.getElementById("name").value = "";
      document.getElementById("artist").value = "";
      document.getElementById("file").value = "";
    }

    // Bulk add songs
    const songsToAdd = [
      { name: "MakeDamnSure", artist: "Taking Back Sunday", file: "https://raw.githubusercontent.com/Tribhuvans/TribhuvanVault/main/makeDamnSure.mp3" },
      { name: "Faint", artist: "Linkin Park", file: "https://raw.githubusercontent.com/Tribhuvans/TribhuvanVault/main/faint.mp3" },
      { name: "Tears Don't Fall", artist: "Bullet for My Valentine", file: "https://raw.githubusercontent.com/Tribhuvans/TribhuvanVault/main/tearsDontFall.mp3" },
      { name: "Photograph", artist: "Nickelback", file: "https://raw.githubusercontent.com/Tribhuvans/TribhuvanVault/main/photograph.mp3" },
      { name: "Lying is the most fun", artist: "Panic at the Disco", file: "https://raw.gitbuhusercontent.com/Tribhuvans/TribhuvanVault/main/lyingisthemostfun.mp3"}
      // Add more songs here in same format
    ];

    async function addAllSongs() {
      for (let song of songsToAdd) {
        await fetch("https://tribhuvanvault.onrender.com/add-song", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(song)
        });
        console.log(`Added: ${song.name} by ${song.artist}`);
      }
      alert("All songs added 🤘");
    }
  </script>

</body>
</html>
